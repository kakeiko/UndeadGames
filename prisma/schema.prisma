// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  steamId   String   @unique
  points    Int      @default(0)

  metas     Meta[]
  medalhas  Medalha[]
}

model Meta {
  id             String  @id @default(cuid())
  jogo           String
  objetivo       String
  points  Int
  concluido      Boolean @default(false)
  donoSteamId String
  dono   User @relation(fields: [donoSteamId], references: [steamId])
  dadosProgresso  DadosProgresso[]
}

model DadosProgresso {
  id             String  @id @default(cuid())
  horaInicial Int
  horaFinal Int
  horaAtual Int
  trofeuInicial Int
  trofeuFinal Int
  trofeuAtual Int
  metaId  String
  meta  Meta @relation(fields: [metaId], references: [id])
}

model Medalha {
  id          String  @id @default(cuid())
  icon        String
  objetivo    String
  conquistada Boolean @default(false)
  donoSteamId String
  dono   User @relation(fields: [donoSteamId], references: [steamId])
}
